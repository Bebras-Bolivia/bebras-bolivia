---
import Layout from "@/layouts/Layout.astro";
import PageComponentsRenderer from "@/components/PageComponentsRenderer.astro";
import data from "@/data/estudiantes.json";

const header = data.header;
const components: any[] = Array.isArray((data as any).components) ? (data as any).components : [];
---

<Layout title="Prueba Mmarket - Estudiantes" description={data.pageDescription}>
  <div class="relative w-full">
    
    <!-- Hero Header (Fijo al fondo) -->
    <div class="sticky top-0 w-full min-h-[70vh] flex flex-col justify-center items-center z-0 pt-20 pb-32">
      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center" data-hero-animate>
        <p class="text-xs uppercase tracking-[0.25em] font-bold text-white mb-4">{header.tag}</p>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-white drop-shadow-sm mb-4">
          {header.heading}
        </h1>
        <p class="mt-6 text-xl text-white font-medium max-w-2xl mx-auto drop-shadow-sm leading-relaxed">
          {header.subtitle}
        </p>
      </div>
    </div>

    <!-- Contenedor Principal (Crema deslizante) -->
    <main class="relative z-10 w-full min-h-screen bg-[#F4F4F1] dark:bg-zinc-950 rounded-t-[3rem] sm:rounded-t-[4rem] -mt-20 shadow-[0_-20px_60px_rgba(0,0,0,0.15)] pb-32 pt-16 lg:pt-24">
      
      <PageComponentsRenderer components={components} />

    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initExpandAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    // Animación de aparición con efecto de revelación desde el centro (Scaling pop-up)
    const revealSections = gsap.utils.toArray<HTMLElement>(".reveal-section");
    
    // Configurar transform-origin para asegurar que escale desde el centro
    gsap.set(revealSections, { transformOrigin: "center center" });

    revealSections.forEach((card) => {
      // Estado inicial: Centro (escala pequeña), un pelín más abajo e invisible
      gsap.set(card, { 
        opacity: 0, 
        y: 60,
        scale: 0.85
      });

      // Animación súper suave al hacer scroll
      gsap.to(card, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.2,
        ease: "power3.out", // Easing muy elegante para expansión desde el centro
        scrollTrigger: {
          trigger: card,
          start: "top 85%", // Empieza a escalar cuando la tarjeta asoma
          toggleActions: "play none none reverse",
        }
      });
    });
  }

  // Ejecutar
  document.addEventListener("astro:page-load", initExpandAnimations);
</script>
