---
import Layout from '../layouts/Layout.astro';
import BebrasBoliviaHome from "../components/BebrasBoliviaHome";
import { getCollection } from "astro:content";
import { BadgeCheck, Brain, School, Sparkles } from "lucide-react";
import PageComponentsRenderer from "@/components/PageComponentsRenderer.astro";
import homeData from "@/data/home.json";
import { formatInlineRichText } from "@/lib/rich-text";
import guacamayoImage from "@/assets/guacamayo.jpg";
import capibaraImage from "@/assets/capibara.jpg";
import titiImage from "@/assets/titi.jpg";
import jukumariImage from "@/assets/jukumari.jpg";
import yaguareteImage from "@/assets/yaguarete.jpg";

const imageMap: Record<string, string> = {
	guacamayo: guacamayoImage.src,
	capibara: capibaraImage.src,
	titi: titiImage.src,
	jucumari: jukumariImage.src,
	yaguarete: yaguareteImage.src,
};

const sections: any[] = Array.isArray((homeData as any).sections) ? (homeData as any).sections : [];
const components: any[] = Array.isArray((homeData as any).components) ? (homeData as any).components : [];
const latestPost = (await getCollection("blog")).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)[0];
const latestNews = latestPost
	? {
		title: latestPost.data.title,
		description: latestPost.data.description,
		author: latestPost.data.author,
		href: `/blog/${latestPost.id.replace(/\.md$/, "")}`,
		dateTime: latestPost.data.date.toISOString(),
		dateLabel: latestPost.data.date.toLocaleDateString("es-BO", {
			year: "numeric",
			month: "short",
			day: "numeric",
		}),
	}
	: null;

function getIntroParagraphs(introSection: any) {
	return Array.isArray(introSection?.paragraphs) && introSection.paragraphs.length > 0
		? introSection.paragraphs
		: [
			"Bebras es una competencia internacional de pensamiento computacional para estudiantes de 6 a 18 años. Los participantes resuelven tareas cortas y lógicas que no requieren conocimientos previos de informática.",
			"La competencia es gratuita y se realiza en tu propia unidad educativa. Cada estudiante cuenta con 45 minutos para resolver las tareas de su categoría.",
		];
}

function getAgeGroups(ageSection: any) {
	return (Array.isArray(ageSection?.items) ? ageSection.items : []).map((item: any) => ({
		...item,
		image: imageMap[item.imageKey] || imageMap.guacamayo,
	}));
}

function getHomeCtaCardClasses(style?: string) {
	if (style === "secondary") {
		return {
			wrapper: "group md:col-span-2 content-card relative overflow-hidden text-foreground p-8 sm:p-10",
			audience: "font-mono text-[10px] uppercase tracking-[0.3em] text-muted-foreground",
			link: "mt-6 inline-flex items-center gap-2 text-sm font-semibold border-b border-foreground/30 pb-0.5 group-hover:border-primary transition-colors",
			iconClass: "size-11 text-ochre",
			emphasisClass: "italic text-primary",
			breakLine: false,
		};
	}

	return {
		wrapper: "group md:col-span-3 relative overflow-hidden rounded-2xl bg-primary text-primary-foreground p-8 sm:p-10 lift-on-hover",
		audience: "font-mono text-[10px] uppercase tracking-[0.3em] opacity-70",
		link: "mt-6 inline-flex items-center gap-2 text-sm font-semibold border-b border-primary-foreground/50 pb-0.5 group-hover:border-primary-foreground transition-colors",
		iconClass: "size-11 opacity-35",
		emphasisClass: "italic",
		breakLine: true,
	};
}

const dotColor: Record<string, string> = {
	rose:    "bg-rose-500",
	amber:   "bg-amber-500",
	emerald: "bg-emerald-500",
	sky:     "bg-sky-500",
	violet:  "bg-violet-500",
	indigo:  "bg-indigo-500",
};
---

<Layout
	title={(homeData as any).seo?.pageTitle || "Inicio"}
	description={(homeData as any).seo?.pageDescription || "Sitio oficial de Bebras Bolivia. Competencia de pensamiento computacional para estudiantes de primaria y secundaria."}
>
	<BebrasBoliviaHome hero={(homeData as any).hero} latestNews={latestNews} client:load />

	<main class="relative z-10 w-full bg-cream dark:bg-zinc-950 pb-16 pt-10 lg:pt-14 grain-paper">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 mb-12">
			<div class="editorial-rule text-foreground/40">
				<Sparkles className="size-5 text-primary" strokeWidth={1.8} aria-hidden="true" />
			</div>
		</div>

					{sections.map((section: any, idx: number) => {
						let content = null;

						if (section.type === "introEditorial") {
							const introParagraphs = getIntroParagraphs(section);
							content = (
								<section data-reveal class="w-full mx-auto max-w-6xl px-4 sm:px-6 mb-12 lg:mb-16">
									<div class="grid grid-cols-12 gap-6 lg:gap-8">
										<aside class="col-span-12 lg:col-span-4">
											<div class="lg:sticky lg:top-28">
												<span class="block display-numeral text-primary text-[5.5rem] sm:text-[7rem] lg:text-[8.5rem] leading-[0.8]">{section.number || "01"}</span>
												<p class="font-mono text-[10px] uppercase tracking-[0.32em] text-muted-foreground mt-3">{section.kicker || "Capítulo uno"}</p>
												<div class="mt-4 h-px w-16 bg-foreground/20"></div>
												<p class="mt-4 font-mono text-xs text-muted-foreground max-w-[20ch] leading-relaxed">{section.asideText || "Una iniciativa de 60+ países que llega a Bolivia."}</p>
											</div>
										</aside>
										<div class="col-span-12 lg:col-span-8">
											<h2 class="serif-display text-[2.9rem] sm:text-[3.6rem] lg:text-[4.4rem] xl:text-[5.1rem] text-foreground mb-8 leading-[0.95]">{section.headingPrefix || "Sobre el"} <em class="italic text-primary">{section.headingEmphasis || "desafío"}</em></h2>
											<div class="space-y-4 text-lg sm:text-xl text-foreground/80 leading-[1.65] max-w-2xl">
												{introParagraphs.map((paragraph: string, pidx: number) => <p class:list={pidx === 0 ? ["first-letter:font-serif first-letter:text-6xl first-letter:float-left first-letter:mr-3 first-letter:leading-[0.9] first-letter:text-primary first-letter:font-normal"] : []} set:html={formatInlineRichText(paragraph)} />)}
											</div>
										</div>
									</div>
								</section>
							);
						} else if (section.type === "homeAgeCategories") {
							const ageGroups = getAgeGroups(section);
							content = (
								<section data-reveal class="w-full mx-auto max-w-6xl px-4 sm:px-6 mb-12 lg:mb-16">
									<div class="grid grid-cols-12 gap-6 lg:gap-8">
										<aside class="col-span-12 lg:col-span-4">
											<div class="lg:sticky lg:top-28">
												<span class="block display-numeral text-primary text-[5.5rem] sm:text-[7rem] lg:text-[8.5rem] leading-[0.8]">{section.number || "02"}</span>
												<p class="font-mono text-[10px] uppercase tracking-[0.32em] text-muted-foreground mt-3">{section.kicker || "Cinco niveles"}</p>
												<div class="mt-4 h-px w-16 bg-foreground/20"></div>
												<p class="mt-4 font-mono text-xs text-muted-foreground max-w-[20ch] leading-relaxed">{section.asideText || "Cada nivel tiene tareas diseñadas para su grupo de edad."}</p>
											</div>
										</aside>
										<div class="col-span-12 lg:col-span-8">
											<h2 class="serif-display text-[2.9rem] sm:text-[3.6rem] lg:text-[4.4rem] xl:text-[5.1rem] text-foreground mb-8 leading-[0.95]">{section.headingPrefix || "Categorías por"} <em class="italic text-primary">{section.headingEmphasis || "edad"}</em></h2>
											<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
												{ageGroups.map((g, i) => (
													<div class="group content-card overflow-hidden">
														<div class="relative aspect-[4/3] overflow-hidden bg-muted">
															<img src={g.image} alt={g.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
															<div class="absolute inset-x-0 bottom-0 translate-y-2 bg-gradient-to-t from-black/55 via-black/24 to-transparent px-4 pb-3 pt-10 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
																<a href={g.authorUrl} target="_blank" rel="noreferrer noopener" class="inline bg-[linear-gradient(currentColor,currentColor)] bg-[length:0_1px] bg-left-bottom bg-no-repeat text-xs font-bold text-white transition-[background-size,color] duration-300 hover:bg-[length:100%_1px] hover:text-primary-foreground">Autor: {g.author}</a>
															</div>
														</div>
														<div class="p-5">
															<div class="flex items-center gap-3 mb-3">
																<span class="font-mono text-xs text-muted-foreground shrink-0 w-6 tabular-nums">{String(i + 1).padStart(2, "0")}</span>
																<span class:list={["size-2 rounded-full shrink-0 transition-transform group-hover:scale-150", dotColor[g.color]]} aria-hidden="true"></span>
																<span class="serif-display italic text-2xl sm:text-3xl text-foreground flex-1">{g.name}</span>
															</div>
															<p class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">{g.range}</p>
														</div>
													</div>
												))}
											</div>
											<div class="mt-6"><a href={section.linkHref || "/estudiantes"} class="link-underline inline-flex items-center gap-2 text-base font-semibold text-primary">{section.linkLabel || "Ver información detallada para estudiantes"}<span aria-hidden="true">→</span></a></div>
										</div>
									</div>
								</section>
							);
						} else if (section.type === "homeDualCta") {
							content = (
								<section data-reveal class="w-full mx-auto max-w-6xl px-4 sm:px-6 mb-12 lg:mb-16">
									<div class="grid grid-cols-1 md:grid-cols-5 gap-4">
										{(section.cards || []).map((card: any) => {
											const ui = getHomeCtaCardClasses(card.style);
											const Icon = card.icon === "school" ? School : Brain;
											return <a href={card.href || "/"} class={ui.wrapper}><div class="flex items-start justify-between gap-4 mb-10"><p class={ui.audience}>{card.audience || "Seccion"}</p><Icon className={ui.iconClass} strokeWidth={1.8} aria-hidden="true" /></div><p class="serif-display text-3xl sm:text-4xl leading-[1.05]">{card.headingPrefix || "Titulo"} <em class={ui.emphasisClass}>{card.headingEmphasis || "destacado"}</em>{ui.breakLine ? <br /> : null}{card.headingSuffix || ""}</p><div class={ui.link}>{card.linkLabel || "Ver mas"}<span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span></div></a>;
										})}
									</div>
								</section>
							);
						} else if (section.type === "aboutBebrasEditorial") {
							content = (
								<section data-reveal class="w-full mx-auto max-w-6xl px-4 sm:px-6">
									<div class="grid grid-cols-12 gap-6 lg:gap-8">
										<aside class="col-span-12 lg:col-span-4">
											<div class="lg:sticky lg:top-28">
												<span class="block display-numeral text-primary text-[5.5rem] sm:text-[7rem] lg:text-[8.5rem] leading-[0.8]">{section.number || "03"}</span>
												<p class="font-mono text-[10px] uppercase tracking-[0.32em] text-muted-foreground mt-3">{section.kicker || "Iniciativa internacional"}</p>
												<div class="mt-4 h-px w-16 bg-foreground/20"></div>
												<p class="mt-4 font-mono text-xs text-muted-foreground max-w-[20ch] leading-relaxed">{section.asideText || "Presente en más de 60 países alrededor del mundo."}</p>
											</div>
										</aside>
										<div class="col-span-12 lg:col-span-8">
											<h2 class="serif-display text-[2.9rem] sm:text-[3.6rem] lg:text-[4.4rem] xl:text-[5.1rem] text-foreground mb-8 leading-[0.95]">{section.headingPrefix || "Sobre"} <em class="italic text-primary">{section.headingEmphasis || "Bebras"}</em><BadgeCheck className="inline-block size-6 align-top text-primary/80" strokeWidth={1.8} aria-hidden="true" /></h2>
											<div class="max-w-3xl space-y-4 text-lg text-foreground/80 leading-[1.65]">{(section.paragraphs || []).map((paragraph: string) => <p set:html={formatInlineRichText(paragraph)} />)}</div>
										</div>
									</div>
								</section>
							);
						}

						if (!content) return null;

						return <>
							{content}
							{idx < sections.length - 1 ? <div class="mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10"><div class="editorial-rule text-foreground/40"><Sparkles className="size-5 text-primary" strokeWidth={1.8} aria-hidden="true" /></div></div> : null}
						</>;
					})}

		{components.length > 0 && <PageComponentsRenderer components={components} />}
	</main>
</Layout>

<script>
	function initHomeReveal() {
		const elements = document.querySelectorAll<HTMLElement>("[data-reveal]:not(.is-revealed)");
		if (elements.length === 0) return;

		elements.forEach((el) => {
			el.style.opacity = "0";
			el.style.transform = "translateY(32px)";
			el.style.transition = "opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1), transform 0.9s cubic-bezier(0.22, 1, 0.36, 1)";
		});

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const el = entry.target as HTMLElement;
						el.style.opacity = "1";
						el.style.transform = "translateY(0)";
						el.classList.add("is-revealed");
						observer.unobserve(el);
					}
				});
			},
			{ threshold: 0.12, rootMargin: "0px 0px -50px 0px" }
		);

		elements.forEach((el) => observer.observe(el));
	}

	function initHomeExperience() {
		initHomeReveal();
	}

	document.addEventListener("astro:page-load", initHomeExperience);
	initHomeExperience();
</script>
