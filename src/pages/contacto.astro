---
import Layout from "@/layouts/Layout.astro";
import InternalPageHero from "@/components/InternalPageHero.astro";
import PageComponentsRenderer from "@/components/PageComponentsRenderer.astro";
import data from "@/data/contact.json";

const contactData = data as any;
const header = contactData.header || { tag: "Comunícate", heading: "Contacto", subtitle: "" };
const components: any[] = Array.isArray(contactData.components) ? contactData.components : [];
---

<Layout title="Contacto" description="Contáctanos para más información sobre el Desafío Bebras Bolivia.">
  <div class="relative w-full">
    <InternalPageHero tag={header.tag} heading={header.heading} description={header.subtitle} />

    <main class="relative z-10 w-full min-h-screen bg-bebras-paper dark:bg-zinc-950 pb-20 pt-10 lg:pt-14">
      <PageComponentsRenderer components={components} />
    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initExpandAnimations() {
    gsap.registerPlugin(ScrollTrigger);
    const revealSections = gsap.utils.toArray<HTMLElement>(".reveal-section");
    gsap.set(revealSections, { transformOrigin: "center center" });

    revealSections.forEach((section) => {
      gsap.set(section, { opacity: 0, y: 44 });
      gsap.to(section, {
        opacity: 1,
        y: 0,
        duration: 1.2,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section,
          start: "top 85%",
          toggleActions: "play none none reverse",
        },
      });
    });
  }

  document.addEventListener("astro:page-load", initExpandAnimations);
  initExpandAnimations();
</script>
