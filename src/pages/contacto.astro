---
import Layout from "@/layouts/Layout.astro";
import PageComponentsRenderer from "@/components/PageComponentsRenderer.astro";
import data from "@/data/contact.json";

const contactData = data as any;
const header = contactData.header || { tag: "Comunicate", heading: "Contacto", subtitle: "" };
const components: any[] = Array.isArray(contactData.components) ? contactData.components : [];
---

<Layout title={header.pageTitle || "Contacto"} description={header.pageDescription || "Contactanos para mas informacion."}>
  <div class="relative w-full">
    <div class="sticky top-0 w-full min-h-[70vh] flex flex-col justify-center items-center z-0 pt-20 pb-32">
      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center" data-hero-animate>
        <p class="text-xs uppercase tracking-[0.25em] font-bold text-white mb-4">{header.tag}</p>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-white drop-shadow-sm mb-4">{header.heading}</h1>
        <p class="mt-6 text-xl text-white font-medium max-w-2xl mx-auto drop-shadow-sm leading-relaxed">{header.subtitle}</p>
      </div>
    </div>

    <main class="relative z-10 w-full min-h-screen bg-[#F4F4F1] dark:bg-zinc-950 rounded-t-[3rem] sm:rounded-t-[4rem] -mt-20 shadow-[0_-20px_60px_rgba(0,0,0,0.15)] pb-32 pt-16 lg:pt-24">
      <PageComponentsRenderer components={components} />
    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initExpandAnimations() {
    gsap.registerPlugin(ScrollTrigger);
    const revealSections = gsap.utils.toArray<HTMLElement>(".reveal-section");
    gsap.set(revealSections, { transformOrigin: "center center" });

    revealSections.forEach((card) => {
      gsap.set(card, { opacity: 0, y: 60, scale: 0.85 });
      gsap.to(card, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.2,
        ease: "power3.out",
        scrollTrigger: {
          trigger: card,
          start: "top 85%",
          toggleActions: "play none none reverse",
        },
      });
    });
  }

  document.addEventListener("astro:page-load", initExpandAnimations);
</script>
