---
import Layout from "@/layouts/Layout.astro";
import data from "@/data/contact.json";

const header = data.header;
const info = data.info;
const intl = data.international;
const form = data.form;

// Icon map for contact cards
const contactIconMap: Record<string, string> = {
  email: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  clipboard: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>`,
  share: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
};
---

<Layout title={data.pageTitle} description={data.pageDescription}>
  <div class="relative w-full">
    
    <!-- Hero Header (compacto) -->
    <div class="relative w-full flex flex-col justify-center items-center pt-10 pb-16 sm:pt-14 sm:pb-20">
      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center" data-hero-animate>
        <p class="text-xs uppercase tracking-[0.25em] font-bold text-white/80 mb-3">{header.tag}</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-white drop-shadow-sm">
          <span class="text-white">{header.heading}</span>
        </h1>
      </div>
    </div>

    <!-- Contenedor Principal (Crema deslizante) -->
    <main class="relative z-10 w-full min-h-screen bg-cream dark:bg-zinc-950 rounded-t-[3rem] sm:rounded-t-[4rem] shadow-[0_-20px_60px_rgba(0,0,0,0.15)] pb-32 pt-14 lg:pt-20">
      
      <!-- Contact section -->
      <section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
        <div class="bg-card dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-border/70">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
            
            <!-- Contact info -->
            <div>
              <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{info.tag}</p>
              <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-10 tracking-tight">{info.heading}</h2>

              <div class="space-y-6">
                {info.cards.map((card) => (
                  <div class="rounded-3xl border border-border/70 bg-accent p-8 transition-transform hover:-translate-y-2 duration-300">
                    <div class="flex items-start gap-6">
                      <div class="flex items-center justify-center size-14 shrink-0 rounded-2xl bg-card text-primary shadow-sm" set:html={contactIconMap[card.icon] || ""}>
                      </div>
                      <div>
                        <p class="text-sm uppercase tracking-[0.15em] font-bold text-muted-foreground mb-2">{card.title}</p>
                        {card.linkHref && card.linkLabel && (
                          <a href={card.linkHref} class="text-lg text-foreground hover:text-primary transition-colors font-bold tracking-tight">
                            {card.linkLabel}
                          </a>
                        )}
                        {card.socialLinks && (
                          <div class="flex gap-4 mt-2">
                            {card.socialLinks.map((social, idx) => (
                              <>
                                {idx > 0 && <span class="text-border">|</span>}
                                <a href={social.href} class="text-base text-muted-foreground hover:text-primary transition-colors font-bold">{social.label}</a>
                              </>
                            ))}
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <!-- International links -->
              <div class="mt-14 p-8 rounded-3xl bg-secondary/40 border border-border/70">
                <p class="text-sm uppercase tracking-[0.15em] font-bold text-muted-foreground mb-6">{intl.tag}</p>
                <div class="rule-line mb-6 opacity-30"></div>
                <ul class="space-y-4">
                  {intl.links.map((link, i) => (
                    <li>
                      <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group inline-flex items-center gap-4 text-base text-foreground font-medium hover:text-primary transition-colors"
                      >
                        <span class="font-mono text-xs text-primary/60 font-bold">{String(i + 1).padStart(2, "0")}</span>
                        <span class="group-hover:translate-x-2 transition-transform">{link.label}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Contact form (UI only) -->
            <div>
              <div class="bg-accent rounded-[2rem] p-10 lg:p-12 border border-border/70 h-full shadow-inner">
                <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{form.tag}</p>
                <h2 class="text-3xl font-bold text-foreground mb-8 tracking-tight">{form.heading}</h2>
                <form class="space-y-6" onsubmit="event.preventDefault()">
                  <div>
                    <label for="name" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">
                      {form.fields.name.label}
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      placeholder={form.fields.name.placeholder}
                      class="w-full rounded-2xl border-none bg-card px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all shadow-sm font-medium"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">
                      {form.fields.email.label}
                    </label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      placeholder={form.fields.email.placeholder}
                      class="w-full rounded-2xl border-none bg-card px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all shadow-sm font-medium"
                    />
                  </div>
                  <div>
                    <label for="role" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">
                      {form.fields.role.label}
                    </label>
                    <select
                      id="role"
                      name="role"
                      class="w-full rounded-2xl border-none bg-card px-5 py-4 text-base text-foreground focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all shadow-sm font-medium appearance-none"
                    >
                      <option value="">{form.fields.role.placeholder}</option>
                      {form.fields.role.options.map((opt) => (
                        <option value={opt.toLowerCase()}>{opt}</option>
                      ))}
                    </select>
                  </div>
                  <div>
                    <label for="message" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">
                      {form.fields.message.label}
                    </label>
                    <textarea
                      id="message"
                      name="message"
                      rows="5"
                      placeholder={form.fields.message.placeholder}
                      class="w-full rounded-2xl border-none bg-card px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all shadow-sm font-medium resize-y"
                    ></textarea>
                  </div>
                  <button
                    type="submit"
                    class="group w-full mt-4 inline-flex items-center justify-center rounded-2xl bg-primary px-8 py-5 text-lg font-bold text-primary-foreground shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all duration-300"
                  >
                    {form.submitLabel}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-3 transition-transform group-hover:translate-x-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </button>
                  <p class="text-xs text-muted-foreground/70 text-center font-mono mt-4 font-medium">
                    {form.disclaimer}
                  </p>
                </form>
              </div>
            </div>

          </div>
        </div>
      </section>
      
    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initExpandAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    const revealSections = gsap.utils.toArray<HTMLElement>(".reveal-section");
    gsap.set(revealSections, { transformOrigin: "center center" });

    revealSections.forEach((card) => {
      gsap.set(card, { 
        opacity: 0, 
        y: 60,
        scale: 0.85
      });

      gsap.to(card, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.2,
        ease: "power3.out",
        scrollTrigger: {
          trigger: card,
          start: "top 85%",
          toggleActions: "play none none reverse",
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initExpandAnimations);
</script>
