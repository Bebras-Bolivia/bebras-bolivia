---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import blogUi from "@/data/blog-ui.json";
import BlogPostArticle from "@/components/BlogPostArticle.astro";
import { renderBlogMarkdown } from "@/lib/blog-markdown";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(
    (post) => post.id.replace(/\.md$/, "") !== "cms-preview"
  );
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const uiData = blogUi as any;
const components: any[] = Array.isArray(uiData.components) ? uiData.components : [];
const postUi = components.find((c) => c.type === "blogPostUi") || {
  backLabel: "Volver al blog",
};
const contentHtml = renderBlogMarkdown(post.body || "");

---

<Layout title={post.data.title} description={post.data.description} image={post.data.image}>
  <BlogPostArticle
    title={post.data.title}
    description={post.data.description}
    date={post.data.date}
    author={post.data.author}
    image={post.data.image}
    postUi={postUi}
    ctaEnabled={post.data.ctaEnabled}
    ctaLabel={post.data.ctaLabel}
    ctaHref={post.data.ctaHref}
    contentHtml={contentHtml}
  />
</Layout>
