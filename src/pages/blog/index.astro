---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import blogUi from "@/data/blog-ui.json";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const ui = blogUi.index;
---

<Layout title={ui.pageTitle} description={ui.pageDescription}>
  <!-- Page header -->
  <section class="relative bg-background py-20 lg:py-24 grain-overlay">
    <div class="absolute inset-0 bg-dot-pattern opacity-30" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xs uppercase tracking-[0.25em] font-semibold text-primary mb-4">{ui.header.tag}</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground">
        <span class="text-primary">{ui.header.headingHighlight}</span> & Noticias
      </h1>
      <p class="mt-5 text-lg text-muted-foreground leading-relaxed">
        {ui.header.subtitle}
      </p>
    </div>
  </section>

  <!-- Blog grid -->
  <section class="bg-muted/30 py-20 lg:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="text-center py-16" data-animate>
          <p class="text-xs uppercase tracking-[0.25em] font-semibold text-primary mb-3">{ui.emptyState.tag}</p>
          <p class="text-muted-foreground text-lg">{ui.emptyState.text}</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.id.replace(/\.md$/, "")}`}
              class="group card-accent-left rounded-xl border border-border bg-card shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 overflow-hidden"
              data-animate
            >
              {post.data.image && (
                <div class="aspect-video overflow-hidden bg-muted">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="font-mono text-xs text-primary/60">{String(i + 1).padStart(2, "0")}</span>
                  <span class="rule-line flex-1"></span>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-xs uppercase tracking-[0.1em] text-muted-foreground font-mono"
                  >
                    {post.data.date.toLocaleDateString("es-BO", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })}
                  </time>
                </div>
                {post.data.author && (
                  <p class="text-xs uppercase tracking-[0.15em] text-muted-foreground/70 font-semibold mb-2">
                    {post.data.author}
                  </p>
                )}
                <h2 class="text-lg font-bold text-foreground group-hover:text-primary transition-colors tracking-tight">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-muted-foreground leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
                <span class="inline-flex items-center gap-1.5 mt-4 text-sm text-primary font-semibold group-hover:translate-x-1 transition-transform">
                  {ui.readMoreLabel}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
