---
import Layout from "@/layouts/Layout.astro";
import FAQQuestionsBlock from "@/components/content-blocks/FAQQuestionsBlock.astro";
import SponsorsCardsBlock from "@/components/content-blocks/SponsorsCardsBlock.astro";
import CtaSectionBlock from "@/components/content-blocks/CtaSectionBlock.astro";
import ContactInfoCardsBlock from "@/components/content-blocks/ContactInfoCardsBlock.astro";
import ContactInternationalBlock from "@/components/content-blocks/ContactInternationalBlock.astro";
import ContactFormBlock from "@/components/content-blocks/ContactFormBlock.astro";
import ContactClassicBlock from "@/components/content-blocks/ContactClassicBlock.astro";
import DocentesRegistroBlock from "@/components/content-blocks/DocentesRegistroBlock.astro";
import DocentesRequisitosBlock from "@/components/content-blocks/DocentesRequisitosBlock.astro";
import DocentesAlcanceBlock from "@/components/content-blocks/DocentesAlcanceBlock.astro";
import TeacherInstructionsTabsBlock from "@/components/content-blocks/TeacherInstructionsTabsBlock.astro";
import data from "@/data/docentes.json";

const header = data.header;
const components: any[] = Array.isArray((data as any).components) ? (data as any).components : [];
---

<Layout title={data.pageTitle} description={data.pageDescription}>
  <div class="relative w-full">
    
    <!-- Hero Header (Fijo al fondo) -->
    <div class="sticky top-0 w-full min-h-[70vh] flex flex-col justify-center items-center z-0 pt-20 pb-32">
      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center" data-hero-animate>
        <p class="text-xs uppercase tracking-[0.25em] font-bold text-white mb-4">{header.tag}</p>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight text-white drop-shadow-sm mb-4">
          {header.heading}
        </h1>
        <p class="mt-6 text-xl text-white font-medium max-w-2xl mx-auto drop-shadow-sm leading-relaxed">
          {header.subtitle}
        </p>
      </div>
    </div>

    <!-- Contenedor Principal (Crema deslizante) -->
    <main class="relative z-10 w-full min-h-screen bg-[#F4F4F1] dark:bg-zinc-950 rounded-t-[3rem] sm:rounded-t-[4rem] -mt-20 shadow-[0_-20px_60px_rgba(0,0,0,0.15)] pb-32 pt-16 lg:pt-24">
      
        {components.map((component: any) => {
          if (component.type === "docentesRegistro") {
            return <DocentesRegistroBlock tag={component.tag} heading={component.heading} intro={component.intro} columns={component.columns} steps={component.steps} />;
          }
          if (component.type === "docentesRequisitos") {
            return <DocentesRequisitosBlock tag={component.tag} heading={component.heading} columns={component.columns} requirements={component.requirements} />;
          }
          if (component.type === "docentesAlcance") {
            return <DocentesAlcanceBlock tag={component.tag} heading={component.heading} content={component.content} tip={component.tip} />;
          }
          if (component.type === "teacherInstructionsTabs") {
            return <TeacherInstructionsTabsBlock sectionTag={component.sectionTag} heading={component.heading} subtitle={component.subtitle} tabs={component.tabs} />;
          }
          if (component.type === "contactInfoCards") {
            return <ContactInfoCardsBlock tag={component.tag} heading={component.heading} cards={component.cards} />;
          }
          if (component.type === "contactInternational") {
            return <ContactInternationalBlock tag={component.tag} links={component.links} />;
          }
          if (component.type === "contactForm") {
            return <ContactFormBlock data={component} />;
          }
          if (component.type === "contactClassic") {
            return <ContactClassicBlock data={component} />;
          }
          if (component.type === "faqQuestions") {
            return <FAQQuestionsBlock categories={component.categories} />;
          }
          if (component.type === "sponsorsCards") {
            return <SponsorsCardsBlock tag={component.tag} columns={component.columns} cards={component.cards} />;
          }
          if (component.type === "cta") {
            return <CtaSectionBlock tag={component.tag} heading={component.heading} text={component.text} buttonLabel={component.buttonLabel} buttonHref={component.buttonHref} />;
          }
          return null;
        })}

    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initExpandAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    // Animación de aparición con efecto de revelación desde el centro (Scaling pop-up)
    const revealSections = gsap.utils.toArray<HTMLElement>(".reveal-section");
    
    // Configurar transform-origin para asegurar que escale desde el centro
    gsap.set(revealSections, { transformOrigin: "center center" });

    revealSections.forEach((card) => {
      // Estado inicial: Centro (escala pequeña), un pelín más abajo e invisible
      gsap.set(card, { 
        opacity: 0, 
        y: 60,
        scale: 0.85
      });

      // Animación súper suave al hacer scroll
      gsap.to(card, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.2,
        ease: "power3.out", // Easing muy elegante para expansión desde el centro
        scrollTrigger: {
          trigger: card,
          start: "top 85%", // Empieza a escalar cuando la tarjeta asoma
          toggleActions: "play none none reverse",
        }
      });
    });
  }

  // Ejecutar
  document.addEventListener("astro:page-load", initExpandAnimations);
</script>
