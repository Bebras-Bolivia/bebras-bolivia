---
import Layout from "@/layouts/Layout.astro";
import data from "@/data/registro.json";
---

<Layout title={data.pageTitle} description={data.pageDescription}>
  <section class="relative bg-background py-24 lg:py-32 grain-overlay">
    <div class="absolute inset-0 bg-dot-pattern opacity-30" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-lg px-4 sm:px-6 lg:px-8 text-center">
      <!-- Icon -->
      <div class="flex justify-center mb-8">
        <div class="flex items-center justify-center size-20 rounded-full border-2 border-primary/30 bg-primary/10 text-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
      </div>

      <p class="text-xs uppercase tracking-[0.25em] font-semibold text-primary mb-4">{data.tag}</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground">
        {data.heading}
      </h1>
      <p class="mt-5 text-lg text-muted-foreground leading-relaxed">
        {data.paragraph}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <span
          class="inline-flex items-center justify-center rounded-lg bg-primary/10 text-primary/50 px-6 py-3.5 text-sm font-semibold cursor-not-allowed border border-primary/20"
          aria-disabled="true"
        >
          {data.disabledButton}
        </span>
        <a
          href={data.backButton.href}
          class="group inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3.5 text-sm font-semibold text-foreground hover:bg-accent transition-all duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 transition-transform group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          {data.backButton.label}
        </a>
      </div>

      <div class="mt-12 card-accent-left rounded-xl border border-primary/20 bg-primary/5 p-6 text-left">
        <p class="text-xs uppercase tracking-[0.15em] font-semibold text-primary mb-2">{data.notification.tag}</p>
        <p class="text-sm text-foreground leading-relaxed">
          <strong>{data.notification.text}</strong> {data.notification.instruction}
          <a href={`mailto:${data.notification.email}`} class="text-primary hover:text-primary/80 underline underline-offset-2 font-medium">{data.notification.email}</a>
          {data.notification.suffix}
        </p>
      </div>
    </div>
  </section>
</Layout>
