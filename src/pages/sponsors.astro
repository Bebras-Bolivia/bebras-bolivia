---
import Layout from "@/layouts/Layout.astro";
import data from "@/data/sponsors.json";

const header = data.header;
const anchor = data.anchor;
const sponsorsSection = data.sponsorsSection;
const sponsors = data.sponsors;
const cta = data.cta;
---

<Layout title={data.pageTitle} description={data.pageDescription}>
  <div class="relative w-full">
    
    <!-- Hero Header (compacto) -->
    <div class="relative w-full flex flex-col justify-center items-center pt-10 pb-16 sm:pt-14 sm:pb-20">
      <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center" data-hero-animate>
        <p class="text-xs uppercase tracking-[0.25em] font-bold text-white/80 mb-3">{header.tag}</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-white drop-shadow-sm">
          Nuestros <span class="text-white">{header.headingHighlight}</span>
        </h1>
      </div>
    </div>

    <!-- Contenedor Principal (Crema deslizante) -->
    <main class="relative z-10 w-full min-h-screen bg-cream dark:bg-zinc-950 rounded-t-[3rem] sm:rounded-t-[4rem] shadow-[0_-20px_60px_rgba(0,0,0,0.15)] pb-32 pt-14 lg:pt-20">
      
      <!-- Main sponsor / anchor institution -->
      <section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
        <div class="bg-card dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-border/70">
          <div class="mx-auto max-w-3xl">
            <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4 text-center">{anchor.tag}</p>
            <div class="rule-line mx-auto max-w-xs mb-10"></div>
            
            <div class="flex justify-center">
              <div class="rounded-3xl border border-border/70 bg-accent p-10 text-left transition-transform hover:-translate-y-2 duration-300 max-w-2xl w-full">
                <div class="flex items-start gap-8">
                  <div class="flex items-center justify-center size-20 shrink-0 rounded-2xl bg-card shadow-md">
                    <img
                      src="/images/sponsors/sponsor-placeholder.svg"
                      alt={anchor.name}
                      class="h-12 w-auto opacity-80"
                    />
                  </div>
                  <div>
                    <span class="font-mono text-sm uppercase tracking-widest text-primary/60 mb-2 block font-bold">00</span>
                    <h3 class="text-2xl font-bold text-foreground mb-3 tracking-tight">{anchor.name}</h3>
                    <p class="text-base text-muted-foreground leading-relaxed">
                      {anchor.description}
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Other sponsors -->
      <section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
        <div class="bg-card dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-border/70">
          <div class="mx-auto max-w-5xl">
            <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4 text-center">{sponsorsSection.tag}</p>
            <div class="rule-line mx-auto max-w-xs mb-10"></div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {sponsors.map((sponsor, i) => (
                <div class="rounded-3xl border border-border/70 bg-accent p-8 text-left transition-transform hover:-translate-y-2 duration-300">
                  <div class="flex items-center gap-4 mb-6">
                    <div class="flex items-center justify-center size-14 shrink-0 rounded-xl bg-card shadow-sm">
                      <img
                        src="/images/sponsors/sponsor-placeholder.svg"
                        alt={sponsor.name}
                        class="h-8 w-auto opacity-70"
                      />
                    </div>
                    <span class="font-mono text-sm uppercase tracking-widest text-primary/60 font-bold">{String(i + 1).padStart(2, "0")}</span>
                  </div>
                  <h3 class="text-xl font-bold text-foreground mb-3 tracking-tight">{sponsor.name}</h3>
                  <p class="text-base text-muted-foreground leading-relaxed">
                    {sponsor.desc}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Become a sponsor CTA -->
      <section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6">
        <div class="bg-card dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-2xl border border-border/70 text-center">
          <div class="mx-auto max-w-3xl">
            <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{cta.tag}</p>
            <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-6 tracking-tight">
              {cta.heading}
            </h2>
            <p class="text-xl text-muted-foreground mb-12 max-w-2xl mx-auto leading-relaxed">
              {cta.paragraph}
            </p>
            <a
              href={cta.buttonHref}
              class="group inline-flex items-center justify-center rounded-2xl bg-primary px-12 py-6 text-xl font-bold text-primary-foreground shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300"
            >
              {cta.buttonLabel}
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-3 transition-transform group-hover:translate-x-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

    </main>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initExpandAnimations() {
    gsap.registerPlugin(ScrollTrigger);

    const revealSections = gsap.utils.toArray<HTMLElement>(".reveal-section");
    gsap.set(revealSections, { transformOrigin: "center center" });

    revealSections.forEach((card) => {
      gsap.set(card, { 
        opacity: 0, 
        y: 60,
        scale: 0.85
      });

      gsap.to(card, {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 1.2,
        ease: "power3.out",
        scrollTrigger: {
          trigger: card,
          start: "top 85%",
          toggleActions: "play none none reverse",
        }
      });
    });
  }

  document.addEventListener("astro:page-load", initExpandAnimations);
</script>
