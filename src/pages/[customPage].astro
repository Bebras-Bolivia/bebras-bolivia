---
import Layout from "@/layouts/Layout.astro";
import DynamicBlocks from "@/components/DynamicBlocks.astro";
import InternalPageHero from "@/components/InternalPageHero.astro";
import customPagesData from "@/data/custom-pages.json";

export async function getStaticPaths() {
  return (customPagesData.pages || []).map((page) => ({
    params: { customPage: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;
---

<Layout title={page.title} description={page.description}>
  <div class="relative w-full">
    <InternalPageHero heading={page.title} description={page.description} sticky />

    <main class="relative z-10 w-full min-h-screen bg-bebras-paper dark:bg-zinc-950 -mt-14 pb-20 pt-10 lg:pt-14">
      <div class="w-full mx-auto max-w-6xl px-4 sm:px-6">
        <DynamicBlocks blocks={(page.blocks || []) as any} />
      </div>
    </main>
  </div>
</Layout>
