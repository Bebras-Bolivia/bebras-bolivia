---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Bebras Bolivia | Desafío Internacional de Pensamiento Computacional",
	description = "Bebras Bolivia promueve el pensamiento computacional en estudiantes de primaria y secundaria mediante desafíos cortos y divertidos.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
