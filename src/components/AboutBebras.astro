---
import aboutData from "@/data/about.json";

const { sectionTag, heading, headingHighlight, subtitle, cards } = aboutData;

// Icon SVGs mapped by key
const iconMap: Record<string, string> = {
  book: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>',
  brain: '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path>',
  calendar: '<path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path>',
};
---

<section class="relative bg-muted/30 py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section header — editorial style -->
    <div data-animate class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <p class="text-xs uppercase tracking-[0.25em] font-semibold text-primary mb-3">{sectionTag}</p>
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight text-foreground leading-tight">
          {heading.replace(headingHighlight, "")}
          <span class="text-primary">{headingHighlight}</span>?
        </h2>
      </div>
      <p class="text-muted-foreground leading-relaxed max-w-md text-sm md:text-base md:text-right">
        {subtitle}
      </p>
    </div>

    <div class="rule-line mb-10"></div>

    <!-- Three columns — editorial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {cards.map((card) => (
        <div data-animate class="card-accent-left rounded-xl border border-border bg-card p-7 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1">
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-flex items-center justify-center size-10 rounded-lg bg-primary/10 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconMap[card.icon] || ""} />
            </span>
            <span class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">{card.number}</span>
          </div>
          <h3 class="text-lg font-bold text-foreground mb-3">{card.title}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            {card.body}
          </p>
          {card.link && (
            <a
              href={card.link.href}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary/80 mt-4 group"
            >
              {card.link.label}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
