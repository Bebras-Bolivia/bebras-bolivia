---
import InternalPageHero from "@/components/InternalPageHero.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  postUi: {
    backLabel?: string;
  };
  ctaLabel?: string;
  ctaHref?: string;
  contentHtml: string;
}

const { title, description, date, author, image, postUi, ctaLabel, ctaHref, contentHtml } = Astro.props;
const showCta = Boolean(ctaLabel && ctaHref);

const formattedDate = date.toLocaleDateString("es-BO", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const heroTag = author ? `${formattedDate} · ${author}` : formattedDate;
---

<div class="relative w-full">
  <InternalPageHero tag={heroTag} heading={title} />

  <article class="relative z-10 bg-bebras-paper py-14 lg:py-16 dark:bg-zinc-950">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <a
      href="/blog"
      class="group inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors mb-6"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      <span class="text-xs uppercase tracking-[0.15em] font-semibold">{postUi.backLabel}</span>
    </a>

    <header class="mb-7">
      <p class="text-lg text-muted-foreground leading-relaxed">
        {description}
      </p>
      <div class="rule-line mt-5"></div>
    </header>

    {image && (
      <div class="overflow-hidden border-y border-border mb-8 py-4">
        <img
          src={image}
          alt={title}
          class="w-full aspect-video object-cover"
        />
      </div>
    )}

    <div class="blog-post-content">
      <Fragment set:html={contentHtml} />
    </div>

    <div class="mt-10 pt-6 border-t border-border">
      <div class:list={["flex flex-col sm:flex-row items-center gap-4", showCta ? "justify-between" : "justify-start"]}>
        <a
          href="/blog"
          class="group inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          <span class="text-xs uppercase tracking-[0.15em] font-semibold">{postUi.backLabel}</span>
        </a>
        {showCta && (
          <a
            href={ctaHref}
            class="group inline-flex items-center justify-center rounded-2xl bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary/90"
          >
            {ctaLabel}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        )}
      </div>
    </div>
  </div>
  </article>
</div>

<style is:global>
  .blog-post-content {
    color: rgba(24, 24, 27, 0.84);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .blog-post-content > *:first-child {
    margin-top: 0;
  }

  .blog-post-content h1,
  .blog-post-content h2,
  .blog-post-content h3 {
    color: var(--color-foreground, #18181b);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 1.75rem 0 0.85rem;
  }

  .blog-post-content h1 {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .blog-post-content h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }

  .blog-post-content h3 {
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
  }

  .blog-post-content p,
  .blog-post-content ul,
  .blog-post-content ol,
  .blog-post-content blockquote,
  .blog-post-content pre,
  .blog-post-content table {
    margin: 0 0 1rem;
  }

  .blog-post-content strong {
    color: var(--color-foreground, #18181b);
    font-weight: 700;
  }

  .blog-post-content a {
    color: var(--color-bebras-green, #1b8f60);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .blog-post-content ul,
  .blog-post-content ol {
    padding-left: 1.35rem;
  }

  .blog-post-content ul {
    list-style: disc;
  }

  .blog-post-content ol {
    list-style: decimal;
  }

  .blog-post-content li {
    margin: 0.35rem 0;
  }

  .blog-post-content li::marker {
    color: var(--color-bebras-green, #1b8f60);
    font-weight: 700;
  }

  .blog-post-content blockquote {
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1rem;
    border-left: 3px solid var(--color-bebras-yellow, #f8ae31);
    color: rgba(24, 24, 27, 0.72);
    font-style: italic;
  }

  .blog-post-content blockquote p:last-child {
    margin-bottom: 0;
  }

  .blog-post-content .post-divider {
    margin: 2rem 0;
    height: 1px;
    width: 100%;
    background: color-mix(in srgb, var(--color-bebras-green, #1b8f60) 22%, transparent);
  }

  .post-image {
    margin: 1.5rem auto;
    display: flex;
    justify-content: center;
  }

  .post-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.02);
  }

  .post-image .post-image-caption {
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(24, 24, 27, 0.6);
    text-align: center;
  }

  .post-image--sm {
    max-width: 40%;
  }

  .post-image--md {
    max-width: 60%;
  }

  .post-image--lg {
    max-width: 80%;
  }

  .post-image--full {
    max-width: 100%;
  }

  @media (max-width: 900px) {
    .post-image--sm,
    .post-image--md,
    .post-image--lg,
    .post-image--full {
      max-width: 100%;
    }
  }
</style>
