---
import scoringData from "@/data/scoring.json";

interface ScoringRow {
  label: string;
  values: string[];
  status: string;
}

interface ScoringStat {
  value: string;
  label: string;
}

interface Props {
  data?: {
    sectionTag: string;
    heading: string;
    subtitle: string;
    tableHeaders: string[];
    rows: ScoringRow[];
    summaryCards: ScoringStat[];
    summaryColumns?: number;
  };
}

const props = Astro.props as Props;
const source = props.data || scoringData;
const { sectionTag, heading, subtitle, tableHeaders, rows, summaryCards, summaryColumns = 2 } = source;

function getSummaryColsClass(columns: number) {
  if (columns <= 1) return "grid-cols-1";
  if (columns === 2) return "grid-cols-1 sm:grid-cols-2";
  if (columns === 3) return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3";
  return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4";
}

const summaryColsClass = getSummaryColsClass(summaryColumns);

const statusStyles: Record<string, { icon: string; cellClass: string }> = {
  positive: { icon: "&#10003;", cellClass: "font-bold text-emerald-600" },
  neutral:  { icon: "&mdash;",  cellClass: "text-muted-foreground" },
  negative: { icon: "&times;",  cellClass: "font-bold text-red-600" },
};

const statusIconStyles: Record<string, string> = {
  positive: "bg-emerald-500/10 text-emerald-600",
  neutral:  "bg-muted text-muted-foreground",
  negative: "bg-red-500/10 text-red-600",
};
---

<section class="editorial-section">
  <div class="mx-auto max-w-3xl">
    <div data-animate class="mb-10 text-center sm:text-left">
      <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-3">{sectionTag}</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-foreground tracking-tight">
        {heading}
      </h2>
      <p class="mt-3 text-lg text-muted-foreground">
        {subtitle}
      </p>
    </div>

    <div data-animate class="overflow-x-auto border-y border-border/70 text-card-foreground">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border/70 bg-foreground/5">
            {tableHeaders.map((header, i) => (
              <th class:list={[
                "px-6 py-5 font-bold uppercase tracking-wider text-xs",
                i === 0 ? "text-left text-foreground" : "text-center text-foreground",
              ]}>
                {header}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, rowIdx) => {
            const styles = statusStyles[row.status];
            const iconStyle = statusIconStyles[row.status];
            return (
              <tr class:list={[
                "hover:bg-foreground/5 transition-colors",
                rowIdx < rows.length - 1 ? "border-b border-border/70" : "",
              ]}>
                <td class="px-6 py-5 text-foreground font-medium flex items-center gap-3">
                  <span class:list={["size-6 rounded-2xl inline-flex items-center justify-center text-xs font-bold shrink-0", iconStyle]} set:html={styles.icon} />
                  {row.label}
                </td>
                {row.values.map((val) => (
                  <td class:list={["px-6 py-5 text-center font-mono text-base font-semibold", styles.cellClass]}>
                    {val}
                  </td>
                ))}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div data-animate class:list={["mt-8 grid gap-6", summaryColsClass]}>
      {summaryCards.map((card) => (
        <div class="content-card p-6 text-center">
          <p class="font-mono text-4xl sm:text-5xl font-extrabold text-primary mb-2">{card.value}</p>
          <p class="text-xs sm:text-sm text-muted-foreground uppercase tracking-widest font-bold">{card.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
