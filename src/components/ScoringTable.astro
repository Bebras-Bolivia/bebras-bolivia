---
import scoringData from "@/data/scoring.json";

const { sectionTag, heading, subtitle, tableHeaders, rows, summaryCards } = scoringData;

const statusStyles: Record<string, { icon: string; cellClass: string }> = {
  positive: { icon: "&#10003;", cellClass: "font-bold text-emerald-600" },
  neutral:  { icon: "&mdash;",  cellClass: "text-muted-foreground" },
  negative: { icon: "&times;",  cellClass: "font-bold text-red-600" },
};

const statusIconStyles: Record<string, string> = {
  positive: "bg-emerald-500/10 text-emerald-600",
  neutral:  "bg-muted text-muted-foreground",
  negative: "bg-red-500/10 text-red-600",
};
---

<section class="py-20 lg:py-24 bg-muted">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div data-animate class="mb-10">
      <p class="text-xs uppercase tracking-[0.25em] font-semibold text-primary mb-3">{sectionTag}</p>
      <h2 class="text-3xl font-bold text-foreground tracking-tight">
        {heading}
      </h2>
      <p class="mt-3 text-muted-foreground">
        {subtitle}
      </p>
    </div>

    <div data-animate class="overflow-x-auto rounded-xl border border-border bg-card shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-muted">
            {tableHeaders.map((header, i) => (
              <th class:list={[
                "px-6 py-4 font-bold uppercase tracking-wider text-xs",
                i === 0 ? "text-left text-foreground" : "text-center text-primary",
              ]}>
                {header}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row, rowIdx) => {
            const styles = statusStyles[row.status];
            const iconStyle = statusIconStyles[row.status];
            return (
              <tr class:list={[
                "hover:bg-muted transition-colors",
                rowIdx < rows.length - 1 ? "border-b border-border" : "",
              ]}>
                <td class="px-6 py-4 text-foreground font-medium flex items-center gap-2">
                  <span class:list={["size-5 rounded-full inline-flex items-center justify-center text-xs", iconStyle]} set:html={styles.icon} />
                  {row.label}
                </td>
                {row.values.map((val) => (
                  <td class:list={["px-6 py-4 text-center font-mono", styles.cellClass]}>
                    {val}
                  </td>
                ))}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div data-animate class="mt-8 grid grid-cols-2 gap-4">
      {summaryCards.map((card) => (
        <div class="rounded-xl border border-border bg-card p-5 text-center shadow-sm card-accent-left">
          <p class="font-mono text-3xl font-bold text-primary">{card.value}</p>
          <p class="text-xs text-muted-foreground mt-1.5 uppercase tracking-wider font-medium">{card.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
