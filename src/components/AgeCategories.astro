---
import catData from "@/data/categories.json";
import guacamayoImage from "@/assets/guacamayo.jpg";
import capibaraImage from "@/assets/capibara.jpg";
import titiImage from "@/assets/titi.jpg";
import jukumariImage from "@/assets/jukumari.jpg";
import yaguareteImage from "@/assets/yaguarete.jpg";

interface Category {
  name: string;
  age: string;
  emoji: string;
  color: string;
  desc: string;
  image?: string;
  author?: string;
  authorUrl?: string;
}

interface Props {
  data?: {
    sectionTag: string;
    heading: string;
    subtitle: string;
    categories: Category[];
  };
}

const props = Astro.props as Props;
const source = props.data || catData;
const { sectionTag, heading, subtitle, categories } = source;

const dotColor: Record<string, string> = {
  rose: "bg-rose-500",
  amber: "bg-amber-500",
  emerald: "bg-emerald-500",
  sky: "bg-sky-500",
  violet: "bg-violet-500",
  indigo: "bg-indigo-500",
  orange: "bg-orange-500",
};

const categoryImages: Record<string, string> = {
  guacamayo: guacamayoImage.src,
  capibara: capibaraImage.src,
  titi: titiImage.src,
  jucumari: jukumariImage.src,
  jukumari: jukumariImage.src,
  yaguarete: yaguareteImage.src,
};

const categoryAuthors: Record<string, string> = {
  guacamayo: "Borochirebelde",
  capibara: "Ludwinsiles",
  titi: "Kozue Kawakami",
  jucumari: "Jonathan Candil Mendez",
  jukumari: "Jonathan Candil Mendez",
  yaguarete: "MauMirror",
};

const categoryAuthorUrls: Record<string, string> = {
  guacamayo: "https://commons.wikimedia.org/wiki/File:Ara_ararauna_en_los_llanos_de_Moxos.jpg",
  capibara: "https://commons.wikimedia.org/wiki/File:Familia_de_capibaras_al_borde_del_rio_en_el_parque_Nacional_Madidi.jpg",
  titi: "https://commons.wikimedia.org/wiki/File:Plecturocebus_donacophilus_143025465.jpg",
  jucumari: "https://commons.wikimedia.org/wiki/File:Tremarctos_ornatus_165975083.jpg",
  jukumari: "https://commons.wikimedia.org/wiki/File:Tremarctos_ornatus_165975083.jpg",
  yaguarete: "https://commons.wikimedia.org/wiki/File:Kubai_Jaguar_(Panthera_onca).jpg",
};

function slugifyName(name: string) {
  return name
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/\s+/g, "-");
}

function getCategoryImage(cat: Category) {
  return cat.image || categoryImages[slugifyName(cat.name)] || guacamayoImage.src;
}

function getCategoryAuthor(cat: Category) {
  return cat.author || categoryAuthors[slugifyName(cat.name)] || "";
}

function getCategoryAuthorUrl(cat: Category) {
  return cat.authorUrl || categoryAuthorUrls[slugifyName(cat.name)] || "";
}
---

<section class="editorial-section">
  <div class="mx-auto max-w-6xl">
    <!-- Section header -->
    <div data-animate class="mb-14 text-center sm:text-left">
      <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-3">{sectionTag}</p>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
        <h2 class="text-3xl lg:text-4xl font-bold tracking-tight text-foreground">
          {heading}
        </h2>
        <p class="text-muted-foreground text-sm md:text-base max-w-md md:text-right">
          {subtitle}
        </p>
      </div>
    </div>

    <div class="rule-line mb-10"></div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {categories.map((cat, i) => (
          <div data-animate class="group content-card overflow-hidden">
            <div class="relative aspect-[4/3] overflow-hidden bg-muted">
              <img
                src={getCategoryImage(cat)}
                alt={cat.name}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              {getCategoryAuthor(cat) && getCategoryAuthorUrl(cat) && (
                <div class="absolute inset-x-0 bottom-0 translate-y-2 bg-gradient-to-t from-black/55 via-black/24 to-transparent px-4 pb-3 pt-10 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
                  <a
                    href={getCategoryAuthorUrl(cat)}
                    target="_blank"
                    rel="noreferrer noopener"
                    class="inline bg-[linear-gradient(currentColor,currentColor)] bg-[length:0_1px] bg-left-bottom bg-no-repeat text-xs font-bold text-white transition-[background-size,color] duration-300 hover:bg-[length:100%_1px] hover:text-primary-foreground"
                  >
                    Autor: {getCategoryAuthor(cat)}
                  </a>
                </div>
              )}
            </div>
            <div class="p-5">
              <div class="mb-3 flex items-center gap-3">
                <span class="w-6 shrink-0 font-mono text-xs tabular-nums text-muted-foreground">{String(i + 1).padStart(2, "0")}</span>
                <span class:list={["size-2 shrink-0 rounded-full transition-transform group-hover:scale-150", dotColor[cat.color] || dotColor.violet]} aria-hidden="true"></span>
                <span class="serif-display flex-1 text-2xl italic text-foreground sm:text-3xl">{cat.name}</span>
              </div>
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted-foreground">{cat.age}</p>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{cat.desc}</p>
            </div>
          </div>
        ))}
    </div>
  </div>
</section>
