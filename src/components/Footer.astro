---
import navData from "@/data/navigation.json";
import siteData from "@/data/site.json";
import castorCircle from "@/assets/castor-circle.png";

const currentYear = new Date().getFullYear();
const { blendWithHero = false } = Astro.props;

const { brand, footerColumns, socialLinks, internationalLinks } = navData;
const socialIconMap: Record<string, string> = {
  facebook:
    '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />',
  instagram:
    '<rect width="20" height="20" x="2" y="2" rx="5" ry="5" /><path d="M16 11.37a4 4 0 1 1-7.75 1.26 4 4 0 0 1 7.75-1.26z" /><line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />',
  email:
    '<rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />',
};
---

<footer class:list={[
  "relative border-t",
  blendWithHero ? "border-white/20 bg-primary/95 text-primary-foreground" : "border-border bg-card",
]}>
  <!-- Top accent gradient line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Main footer content -->
    <div class="grid grid-cols-1 gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={brand.href} class="flex items-center gap-3 group">
          <img
            src={castorCircle.src}
            alt={`${brand.name} ${brand.suffix}`}
            class="size-9 rounded-full object-cover ring-1 ring-black/10"
          />
          <div class="flex flex-col">
            <span class:list={["text-base font-bold tracking-tight leading-tight", blendWithHero ? "text-primary-foreground" : "text-foreground"]}>
              {brand.name}
            </span>
            <span class:list={["text-[10px] uppercase tracking-[0.2em] font-medium leading-tight", blendWithHero ? "text-primary-foreground/70" : "text-muted-foreground"]}>
              {brand.suffix}
            </span>
          </div>
        </a>
        <p class:list={["mt-4 text-sm leading-relaxed max-w-xs", blendWithHero ? "text-primary-foreground/80" : "text-muted-foreground"]}>
          {siteData.brandDescription}
        </p>
        <!-- Social icons -->
        <div class="mt-5 flex gap-2">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              aria-label={link.label}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "inline-flex items-center justify-center size-9 rounded-lg hover:-translate-y-px transition-all duration-200",
                blendWithHero
                  ? "border border-white/30 text-primary-foreground/80 hover:text-primary-foreground hover:border-white/60"
                  : "border border-border text-muted-foreground hover:text-primary hover:border-primary/30",
              ]}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={socialIconMap[link.icon] ?? socialIconMap.email}
              />
            </a>
          ))}
        </div>
      </div>

      <!-- Dynamic footer columns -->
      {footerColumns.map((column) => (
        <div>
          <h3 class:list={["text-xs uppercase tracking-[0.2em] font-bold mb-4", blendWithHero ? "text-primary-foreground" : "text-foreground"]}>{column.title}</h3>
          <ul class="space-y-2.5">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={["text-sm transition-colors duration-200", blendWithHero ? "text-primary-foreground/80 hover:text-primary-foreground" : "text-muted-foreground hover:text-primary"]}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- International -->
      <div>
        <h3 class:list={["text-xs uppercase tracking-[0.2em] font-bold mb-4", blendWithHero ? "text-primary-foreground" : "text-foreground"]}>Comunidad</h3>
        <ul class="space-y-2.5">
          {internationalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class:list={["text-sm transition-colors duration-200", blendWithHero ? "text-primary-foreground/80 hover:text-primary-foreground" : "text-muted-foreground hover:text-primary"]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class:list={["py-6 flex flex-col sm:flex-row items-center justify-between gap-3", blendWithHero ? "border-t border-white/20" : "border-t border-border"]}>
      <p class:list={["text-xs", blendWithHero ? "text-primary-foreground/70" : "text-muted-foreground"]}>
        &copy; {currentYear} {siteData.copyrightText}
      </p>
      <p class:list={["text-xs", blendWithHero ? "text-primary-foreground/70" : "text-muted-foreground"]}>
        {siteData.trademarkNote} &mdash;
        <a
          href={siteData.trademarkUrl}
          target="_blank"
          rel="noopener noreferrer"
          class:list={["transition-colors underline underline-offset-2", blendWithHero ? "hover:text-primary-foreground" : "hover:text-primary"]}
        >
          bebras.org
        </a>
      </p>
    </div>
  </div>
</footer>
