---
import navData from "@/data/navigation.json";
import siteData from "@/data/site.json";

const currentYear = new Date().getFullYear();
const { socialLinks } = navData;

const socialIconMap: Record<string, string> = {
  facebook:
    '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />',
  instagram:
    '<rect width="20" height="20" x="2" y="2" rx="5" ry="5" /><path d="M16 11.37a4 4 0 1 1-7.75 1.26 4 4 0 0 1 7.75-1.26z" /><line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />',
  email:
    '<rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />',
};
---

<footer class="relative z-10 w-full bg-cream dark:bg-zinc-950 border-t border-border/70">
  <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-5">
    <div class="text-center sm:text-left">
      <p class="text-sm font-semibold text-foreground">
        &copy; {currentYear} {siteData.copyrightText}
      </p>
      <p class="text-xs text-muted-foreground mt-1">
        {siteData.trademarkNote} &mdash;
        <a
          href={siteData.trademarkUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-primary underline underline-offset-2"
        >
          bebras.org
        </a>
      </p>
    </div>

    <div class="flex gap-2">
      {socialLinks.map((link) => (
        <a
          href={link.href}
          aria-label={link.label}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center size-10 rounded-2xl bg-primary text-primary-foreground hover:-translate-y-0.5 hover:shadow-md transition-all duration-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={socialIconMap[link.icon] ?? socialIconMap.email}
          />
        </a>
      ))}
    </div>
  </div>
</footer>
