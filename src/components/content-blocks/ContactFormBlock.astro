---
interface ContactFormField {
  label: string;
  placeholder: string;
}

interface ContactFormData {
  tag: string;
  heading: string;
  fields: {
    name: ContactFormField;
    email: ContactFormField;
    role: ContactFormField & { options: string[] };
    message: ContactFormField;
  };
  submitLabel: string;
  disclaimer: string;
}

interface Props {
  data: ContactFormData;
}

const { data } = Astro.props;
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-3xl">
      <div class="editorial-callout px-6 py-6 lg:px-8 lg:py-8 h-full">
        <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{data.tag}</p>
        <h2 class="text-3xl font-bold text-foreground mb-8 tracking-tight">{data.heading}</h2>
        <form class="space-y-4" onsubmit="return false;">
          <div>
            <label for="name" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.fields.name.label}</label>
            <input type="text" id="name" name="name" placeholder={data.fields.name.placeholder} class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium" />
          </div>
          <div>
            <label for="email" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.fields.email.label}</label>
            <input type="email" id="email" name="email" placeholder={data.fields.email.placeholder} class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium" />
          </div>
          <div>
            <label for="role" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.fields.role.label}</label>
            <select id="role" name="role" class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium appearance-none">
              <option value="">{data.fields.role.placeholder}</option>
              {data.fields.role.options.map((opt) => (
                <option value={opt.toLowerCase()}>{opt}</option>
              ))}
            </select>
          </div>
          <div>
            <label for="message" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.fields.message.label}</label>
            <textarea id="message" name="message" rows="5" placeholder={data.fields.message.placeholder} class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium resize-y"></textarea>
          </div>
          <button type="submit" class="group w-full mt-4 inline-flex items-center justify-center rounded-2xl bg-primary px-8 py-5 text-lg font-bold text-primary-foreground transition-all duration-300 hover:scale-[1.02] hover:bg-primary/90">
            {data.submitLabel}
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-3 transition-transform group-hover:translate-x-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <p class="text-xs text-muted-foreground/70 text-center font-mono mt-4 font-medium">{data.disclaimer}</p>
        </form>
      </div>
    </div>
  </div>
</section>
