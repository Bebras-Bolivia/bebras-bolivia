---
import { formatInlineRichText } from "@/lib/rich-text";

interface Stat {
  value: string;
  label: string;
}

interface Props {
  tag?: string;
  heading?: string;
  columns?: number;
  stats: Stat[];
  paragraphs?: string[];
}

const { tag, heading, columns = 3, stats = [], paragraphs = [] } = Astro.props;

function getColsClass(cols: number) {
  if (cols <= 1) return "grid-cols-1";
  if (cols === 2) return "grid-cols-1 sm:grid-cols-2";
  if (cols === 3) return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3";
  return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4";
}

function getBrandCardClass(index: number) {
  const colors = ["brand-card-green", "brand-card-yellow", "brand-card-red", "brand-card-blue"];
  return `brand-card ${colors[index % colors.length]}`;
}
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section overflow-hidden">
    <div class="mx-auto max-w-6xl relative z-10">
      {tag && <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{tag}</p>}
      {heading && <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-6 tracking-tight">{heading}</h2>}
      <div class:list={["grid gap-5 mb-7", getColsClass(columns)]}>
        {stats.map((stat, i) => (
          <div class:list={["p-8 text-center", getBrandCardClass(i)]}>
            <p class="font-mono text-5xl font-extrabold mb-3">{stat.value}</p>
            <p class="brand-card-muted text-sm uppercase tracking-widest font-bold">{stat.label}</p>
          </div>
        ))}
      </div>
      {paragraphs.length > 0 && (
        <div class="space-y-4 text-xl text-muted-foreground leading-relaxed">
          {paragraphs.map((p) => <p set:html={formatInlineRichText(p)} />)}
        </div>
      )}
    </div>
  </div>
</section>
