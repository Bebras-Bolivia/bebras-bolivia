---
import { Clock, Mail, Monitor, Users, Wifi } from "lucide-react";
import { formatInlineRichText } from "@/lib/rich-text";

interface GridItem {
  title?: string;
  description?: string;
  icon?: string;
  image?: string;
  number?: string;
  linkLabel?: string;
  linkHref?: string;
  socialLinks?: { label: string; href: string }[];
}

interface Props {
  tag?: string;
  heading?: string;
  intro?: string;
  columns?: number;
  mediaType?: "icon" | "image" | "number" | "none";
  items: GridItem[];
}

const { tag, heading, intro, columns = 3, mediaType = "none", items = [] } = Astro.props;

function normalizedMediaType(type: string) {
  if (type === "icon" || type === "image" || type === "number" || type === "none") return type;
  return "none";
}

const effectiveMediaType = normalizedMediaType(mediaType);

const iconMap = {
  monitor: Monitor,
  wifi: Wifi,
  user: Users,
  clock: Clock,
  email: Mail,
};

function getColsClass(cols: number) {
  if (cols <= 1) return "grid-cols-1";
  if (cols === 2) return "grid-cols-1 sm:grid-cols-2";
  if (cols === 3) return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3";
  return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4";
}

function getBrandCardClass(index: number) {
  const colors = ["brand-card-red", "brand-card-yellow", "brand-card-green", "brand-card-blue"];
  return `brand-card ${colors[index % colors.length]}`;
}
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-6xl">
      {tag && <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-3">{tag}</p>}
      {heading && <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-5 tracking-tight">{heading}</h2>}
      {intro && <p class="text-xl text-muted-foreground leading-relaxed mb-6" set:html={formatInlineRichText(intro)} />}
      <div class:list={["grid gap-5", getColsClass(columns)]}>
        {items.map((item, i) => {
          const Icon = iconMap[item.icon as keyof typeof iconMap];

          return (
          <div class:list={["p-5 text-left", getBrandCardClass(i)]}>
            {effectiveMediaType !== "none" && (
              <div class="mb-4">
                {effectiveMediaType === "number" && (
                  <div class="brand-card-icon flex items-center justify-center size-12 rounded-2xl font-mono">
                    <span class="text-xl font-bold">{item.number || String(i + 1)}</span>
                  </div>
                )}
                {effectiveMediaType === "icon" && (
                  <div class="brand-card-icon flex items-center justify-center size-12 rounded-2xl">
                    {Icon && <Icon className="size-6" strokeWidth={2.2} aria-hidden="true" />}
                  </div>
                )}
                {effectiveMediaType === "image" && (
                  <div class="flex items-center justify-center size-12 rounded-2xl bg-white">
                    <img src={item.image || "/images/sponsors/sponsor-placeholder.svg"} alt={item.title || "Imagen"} class="h-8 w-auto opacity-80" />
                  </div>
                )}
              </div>
            )}
            {item.title && <p class="text-xl font-bold mb-3">{item.title}</p>}
            {item.description && <p class="brand-card-muted text-base leading-relaxed" set:html={formatInlineRichText(item.description)} />}
            {item.linkLabel && item.linkHref && (
              <a href={item.linkHref} class="inline-flex mt-4 text-sm font-semibold hover:underline">{item.linkLabel}</a>
            )}
            {item.socialLinks && item.socialLinks.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-3">
                {item.socialLinks.map((social) => (
                  <a href={social.href} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold hover:underline">
                    {social.label}
                  </a>
                ))}
              </div>
            )}
          </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
