---
import { ArrowRight } from "lucide-react";
import { normalizeBrandColor } from "@/lib/brand-styles";
import { formatInlineRichText } from "@/lib/rich-text";

interface Props {
  tag?: string;
  heading?: string;
  paragraphs?: string[];
  tip?: string;
  linkLabel?: string;
  linkHref?: string;
  accent?: string;
}

const { tag, heading, paragraphs = [], tip, linkLabel, linkHref, accent = "blue" } = Astro.props;
const accentColor = normalizeBrandColor(accent);
const tipCardClass = `brand-card brand-card-${accentColor}`;
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-6xl">
      {tag && <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-3">{tag}</p>}
      {heading && <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-5 tracking-tight">{heading}</h2>}
      <div class="space-y-4 text-xl text-muted-foreground leading-relaxed">
        {paragraphs.map((p) => <p set:html={formatInlineRichText(p)} />)}
        {tip && (
          <div class:list={["px-6 py-5 mt-6", tipCardClass]}>
            <p class="brand-card-muted text-lg font-medium italic leading-relaxed" set:html={formatInlineRichText(tip)} />
          </div>
        )}
        {linkLabel && linkHref && (
          <p class="mt-6">
            <a href={linkHref} class="inline-flex items-center text-primary font-bold group text-xl transition-all">
              {linkLabel}
              <ArrowRight className="ml-2 size-6 transition-transform group-hover:translate-x-1" strokeWidth={2.5} aria-hidden="true" />
            </a>
          </p>
        )}
      </div>
    </div>
  </div>
</section>
