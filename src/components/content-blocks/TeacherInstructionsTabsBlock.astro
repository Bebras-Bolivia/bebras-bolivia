---
import TeacherInstructions from "@/components/TeacherInstructions";

interface Item {
  title: string;
  desc: string;
}

interface Tab {
  id: string;
  label: string;
  heading: string;
  items: Item[];
}

interface Props {
  sectionTag: string;
  heading: string;
  subtitle: string;
  tabs: Tab[];
  cardPalette?: string[];
}

const { sectionTag, heading, subtitle, tabs = [], cardPalette } = Astro.props;
---

<div class="reveal-section w-full mx-auto max-w-6xl mb-8 lg:mb-10 px-4 sm:px-6">
  <TeacherInstructions sectionTag={sectionTag} heading={heading} subtitle={subtitle} tabs={tabs} cardPalette={cardPalette} client:visible />
</div>
