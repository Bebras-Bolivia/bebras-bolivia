---
import { ClipboardList, Mail, Share2 } from "lucide-react";
import { getBrandCardClass } from "@/lib/brand-styles";

interface SocialLink {
  label: string;
  href: string;
}

interface ContactCard {
  icon: string;
  title: string;
  description: string;
  linkLabel?: string;
  linkHref?: string;
  socialLinks?: SocialLink[];
}

interface ContactClassicData {
  info: {
    tag: string;
    heading: string;
    cards: ContactCard[];
  };
  international: {
    tag: string;
    links: { label: string; href: string; description: string }[];
  };
  form: {
    tag: string;
    heading: string;
    fields: {
      name: { label: string; placeholder: string };
      email: { label: string; placeholder: string };
      role: { label: string; placeholder: string; options: string[] };
      message: { label: string; placeholder: string };
    };
    submitLabel: string;
    disclaimer: string;
  };
  cardPalette?: string[];
}

interface Props {
  data: ContactClassicData;
}

const { data } = Astro.props;

const contactIconMap = {
  email: Mail,
  clipboard: ClipboardList,
  share: Share2,
};

---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <div>
        <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{data.info.tag}</p>
        <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-6 tracking-tight">{data.info.heading}</h2>

        <div class="space-y-4">
          {data.info.cards.map((card, i) => {
            const Icon = contactIconMap[card.icon as keyof typeof contactIconMap];

            return (
            <div class:list={["p-6", getBrandCardClass(i, data.cardPalette)]}>
              <div class="flex items-start gap-6">
                <div class="brand-card-icon flex items-center justify-center size-12 shrink-0 rounded-2xl">
                  {Icon && <Icon className="size-6" strokeWidth={2.2} aria-hidden="true" />}
                </div>
                <div>
                  <p class="brand-card-muted text-sm uppercase tracking-[0.15em] font-bold mb-2">{card.title}</p>
                  {card.linkHref && card.linkLabel && (
                    <a href={card.linkHref} class="text-lg font-bold tracking-tight hover:underline">{card.linkLabel}</a>
                  )}
                  {card.socialLinks && (
                    <div class="flex gap-4 mt-2">
                      {card.socialLinks.map((social, idx) => (
                        <>
                          {idx > 0 && <span class="brand-card-muted">|</span>}
                          <a href={social.href} class="brand-card-muted text-base hover:underline font-bold">{social.label}</a>
                        </>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
            );
          })}
        </div>

        <div class="editorial-callout mt-14 px-6 py-8">
          <p class="text-sm uppercase tracking-[0.15em] font-bold text-muted-foreground mb-6">{data.international.tag}</p>
          <div class="rule-line mb-6 opacity-30"></div>
          <ul class="space-y-4">
            {data.international.links.map((link, i) => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-4 text-base text-foreground font-medium hover:text-primary transition-colors">
                  <span class="font-mono text-xs text-primary/60 font-bold">{String(i + 1).padStart(2, "0")}</span>
                  <span class="group-hover:translate-x-2 transition-transform">{link.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div>
        <div class="editorial-callout px-6 py-6 lg:px-8 lg:py-8 h-full">
          <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{data.form.tag}</p>
          <h2 class="text-3xl font-bold text-foreground mb-8 tracking-tight">{data.form.heading}</h2>
          <form class="space-y-4" onsubmit="return false;">
            <div>
              <label for="name" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.form.fields.name.label}</label>
              <input type="text" id="name" name="name" placeholder={data.form.fields.name.placeholder} class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium" />
            </div>
            <div>
              <label for="email" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.form.fields.email.label}</label>
              <input type="email" id="email" name="email" placeholder={data.form.fields.email.placeholder} class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium" />
            </div>
            <div>
              <label for="role" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.form.fields.role.label}</label>
              <select id="role" name="role" class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium appearance-none">
                <option value="">{data.form.fields.role.placeholder}</option>
                {data.form.fields.role.options.map((opt) => (
                  <option value={opt.toLowerCase()}>{opt}</option>
                ))}
              </select>
            </div>
            <div>
              <label for="message" class="block text-xs uppercase tracking-[0.15em] font-bold text-muted-foreground mb-3">{data.form.fields.message.label}</label>
              <textarea id="message" name="message" rows="5" placeholder={data.form.fields.message.placeholder} class="w-full rounded-2xl border border-border bg-white px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/50 focus:outline-none focus:ring-4 focus:ring-primary/20 transition-all font-medium resize-y"></textarea>
            </div>
            <button type="submit" class="group w-full mt-4 inline-flex items-center justify-center rounded-2xl bg-primary px-8 py-5 text-lg font-bold text-primary-foreground transition-all duration-300 hover:scale-[1.02] hover:bg-primary/90">
              {data.form.submitLabel}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-3 transition-transform group-hover:translate-x-2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
            <p class="text-xs text-muted-foreground/70 text-center font-mono mt-4 font-medium">{data.form.disclaimer}</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
