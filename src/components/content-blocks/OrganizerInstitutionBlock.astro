---
import { normalizeBrandColor } from "@/lib/brand-styles";

interface Props {
  tag?: string;
  name: string;
  acronym?: string;
  location?: string;
  role?: string;
  description?: string;
  image?: string;
  linkLabel?: string;
  linkHref?: string;
  accent?: string;
}

const {
  tag,
  name,
  acronym,
  location,
  role,
  description,
  image,
  linkLabel = "Visitar sitio",
  linkHref,
  accent,
} = Astro.props;

const normalizedAccent = accent ? normalizeBrandColor(accent) : undefined;
const cardColorClass = normalizedAccent
  ? `brand-card-${normalizedAccent}`
  : tag?.toLowerCase().includes("aliada") ? "brand-card-green" : "brand-card-blue";
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-6xl">
      {tag && <p class="mb-4 text-sm font-bold uppercase tracking-[0.25em] text-primary">{tag}</p>}

      <article class:list={["brand-card overflow-hidden p-0 text-left", cardColorClass]}>
        <div class="grid items-stretch gap-0 md:grid-cols-[0.82fr_1.18fr]">
          <div class="flex min-h-48 items-center justify-center bg-white px-6 py-8 sm:px-8 md:min-h-full">
            {image ? (
              <img src={image} alt={`Logo ${name}`} class="max-h-32 w-auto max-w-full object-contain sm:max-h-36" />
            ) : (
              <span class="text-4xl font-black tracking-tight text-primary">{acronym || name}</span>
            )}
          </div>

          <div class="flex flex-col justify-center px-6 py-7 sm:px-8 sm:py-8 lg:px-9">
            <div class="mb-4 flex flex-wrap items-center gap-3">
              {acronym && (
                <span class="brand-card-icon rounded-2xl px-3 py-1.5 text-sm font-bold">
                  {acronym}
                </span>
              )}
              {location && (
                <span class="brand-card-icon rounded-2xl px-3 py-1.5 text-sm font-semibold">
                  {location}
                </span>
              )}
            </div>

            <h2 class="mb-3 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
              {name}
            </h2>

            {role && <p class="brand-card-muted mb-3 text-lg font-bold leading-snug">{role}</p>}
            {description && <p class="brand-card-muted max-w-2xl text-base leading-relaxed sm:text-lg">{description}</p>}

            {linkHref && (
              <div class="mt-5">
                <a
                  href={linkHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center rounded-2xl bg-white/18 px-4 py-2.5 text-sm font-bold text-white transition-colors hover:bg-white/24"
                >
                  {linkLabel}
                  <span class="ml-2" aria-hidden="true">-&gt;</span>
                </a>
              </div>
            )}
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
