---
interface SponsorCard {
  name: string;
  desc: string;
  image: string;
}

interface Props {
  tag: string;
  columns: number;
  cards: SponsorCard[];
}

const { tag, columns = 3, cards = [] } = Astro.props;

function getColsClass(cols: number) {
  if (cols <= 1) return "grid-cols-1";
  if (cols === 2) return "grid-cols-1 sm:grid-cols-2";
  if (cols === 3) return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3";
  return "grid-cols-1 sm:grid-cols-2 lg:grid-cols-4";
}

const colsClass = getColsClass(columns);
---

<section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
  <div class="bg-white dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-black/5 dark:border-white/5">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4 text-center">{tag}</p>
      <div class="rule-line mx-auto max-w-xs mb-10"></div>

      <div class:list={["grid gap-6", colsClass]}>
        {cards.map((card, i) => (
          <div class="rounded-3xl border border-black/5 dark:border-white/5 bg-accent p-8 text-left transition-transform hover:-translate-y-2 duration-300">
            <div class="flex items-center gap-4 mb-6">
              <div class="flex items-center justify-center size-14 shrink-0 rounded-xl bg-white shadow-sm">
                <img src={card.image || "/images/sponsors/sponsor-placeholder.svg"} alt={card.name} class="h-8 w-auto opacity-70" />
              </div>
              <span class="font-mono text-sm uppercase tracking-widest text-primary/60 font-bold">{String(i + 1).padStart(2, "0")}</span>
            </div>
            <h3 class="text-xl font-bold text-foreground mb-3 tracking-tight">{card.name}</h3>
            <p class="text-base text-muted-foreground leading-relaxed">{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
