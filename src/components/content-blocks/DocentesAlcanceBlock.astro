---
interface Props {
  tag: string;
  heading: string;
  content: string[];
  tip: string;
}

const { tag, heading, content = [], tip } = Astro.props;
---

<section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
  <div class="bg-white dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-black/5 dark:border-white/5">
    <div class="mx-auto max-w-3xl">
      <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{tag}</p>
      <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-8 tracking-tight">{heading}</h2>
      <div class="space-y-6 text-xl text-muted-foreground leading-relaxed">
        {content.map((p) => <p>{p}</p>)}
        {tip && (
          <div class="rounded-3xl border border-primary/20 bg-primary/5 p-8 mt-10">
            <p class="text-lg text-foreground font-medium italic leading-relaxed">{tip}</p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
