---
interface Item {
  title: string;
  desc: string;
}

interface Props {
  tag?: string;
  heading?: string;
  intro?: string;
  items: Item[];
  outro?: string;
}

const { tag, heading, intro, items = [], outro } = Astro.props;
---

<section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
  <div class="bg-white dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-black/5 dark:border-white/5">
    <div class="mx-auto max-w-3xl">
      {tag && <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{tag}</p>}
      {heading && <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-8 tracking-tight">{heading}</h2>}
      <div class="space-y-6 text-xl text-muted-foreground leading-relaxed">
        {intro && <p>{intro}</p>}
        <ul class="space-y-6 mt-8">
          {items.map((item) => (
            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-muted/50 transition-colors">
              <span class="flex items-center justify-center size-8 shrink-0 rounded-full bg-primary/10 text-primary mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span><strong class="text-foreground text-2xl block mb-2">{item.title}</strong> <span class="text-lg">{item.desc}</span></span>
            </li>
          ))}
        </ul>
        {outro && <p class="pt-6 font-medium text-foreground/80">{outro}</p>}
      </div>
    </div>
  </div>
</section>
