---
import { getBrandCardClass } from "@/lib/brand-styles";
import { formatInlineRichText } from "@/lib/rich-text";

interface Item {
  title: string;
  desc: string;
}

interface Props {
  tag?: string;
  heading?: string;
  intro?: string;
  items: Item[];
  outro?: string;
  cardPalette?: string[];
}

const { tag, heading, intro, items = [], outro, cardPalette } = Astro.props;
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-6xl">
      {tag && <p class="text-sm uppercase tracking-[0.25em] font-bold text-primary mb-4">{tag}</p>}
      {heading && <h2 class="text-4xl sm:text-5xl font-bold text-foreground mb-8 tracking-tight">{heading}</h2>}
      <div class="max-w-5xl space-y-4 text-xl text-muted-foreground leading-relaxed">
        {intro && <p set:html={formatInlineRichText(intro)} />}
        <ul class="mt-8 grid gap-5 md:grid-cols-2">
          {items.map((item, i) => (
            <li class:list={["group flex min-h-44 items-start gap-5 overflow-hidden p-6 sm:p-7", getBrandCardClass(i, cardPalette)]}>
              <span class="brand-card-icon mt-0.5 flex size-12 shrink-0 items-center justify-center rounded-2xl font-mono text-base font-bold tabular-nums transition-transform duration-300 group-hover:scale-105">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span class="min-w-0 flex-1">
                <strong class="block text-2xl font-bold leading-tight sm:text-3xl">{item.title}</strong>
                <span class="brand-card-muted mt-3 block text-base leading-relaxed sm:text-lg">{item.desc}</span>
              </span>
            </li>
          ))}
        </ul>
        {outro && <p class="pt-6 font-medium text-foreground/80" set:html={formatInlineRichText(outro)} />}
      </div>
    </div>
  </div>
</section>
