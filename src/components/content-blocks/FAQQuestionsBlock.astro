---
import FAQAccordion from "@/components/FAQAccordion";

interface FAQItem {
  question: string;
  answer: string;
}

interface FAQCategory {
  title: string;
  items: FAQItem[];
}

interface Props {
  categories: FAQCategory[];
}

const { categories } = Astro.props;
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-6xl">
      <FAQAccordion categories={categories} client:visible />
    </div>
  </div>
</section>
