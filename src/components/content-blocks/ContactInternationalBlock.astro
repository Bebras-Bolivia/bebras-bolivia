---
interface IntlLink {
  label: string;
  href: string;
  description: string;
}

interface Props {
  tag: string;
  links: IntlLink[];
}

const { tag, links = [] } = Astro.props;
---

<section class="reveal-section opacity-0 w-full mx-auto max-w-6xl px-4 sm:px-6 mb-16 lg:mb-24">
  <div class="bg-white dark:bg-card rounded-[2.5rem] p-10 lg:p-16 shadow-xl border border-black/5 dark:border-white/5">
    <div class="mx-auto max-w-4xl">
      <div class="p-8 rounded-3xl bg-secondary/30 border border-black/5 dark:border-white/5">
        <p class="text-sm uppercase tracking-[0.15em] font-bold text-muted-foreground mb-6">{tag}</p>
        <div class="rule-line mb-6 opacity-30"></div>
        <ul class="space-y-4">
          {links.map((link, i) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-4 text-base text-foreground font-medium hover:text-primary transition-colors">
                <span class="font-mono text-xs text-primary/60 font-bold">{String(i + 1).padStart(2, "0")}</span>
                <span class="group-hover:translate-x-2 transition-transform">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
