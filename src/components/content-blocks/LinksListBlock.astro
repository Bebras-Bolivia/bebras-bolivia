---
import { getBrandCardClass } from "@/lib/brand-styles";

interface LinkItem {
  label: string;
  href: string;
  description?: string;
}

interface Props {
  tag?: string;
  heading?: string;
  links: LinkItem[];
  cardPalette?: string[];
}

const { tag, heading, links = [], cardPalette } = Astro.props;
---

<section class="reveal-section w-full mx-auto max-w-6xl px-4 sm:px-6 mb-8 lg:mb-10">
  <div class="editorial-section">
    <div class="mx-auto max-w-3xl">
      {tag && <p class="text-sm uppercase tracking-[0.15em] font-bold text-muted-foreground mb-6">{tag}</p>}
      {heading && <h2 class="text-3xl font-bold text-foreground mb-8 tracking-tight">{heading}</h2>}
      <ul class="space-y-4">
        {links.map((link, i) => (
          <li class:list={["px-5 py-4", getBrandCardClass(i, cardPalette)]}>
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-4 text-base font-medium">
              <span>{link.label}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            {link.description && <p class="brand-card-muted text-sm mt-2">{link.description}</p>}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
