# CMS Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Public path where the CMS is mounted.
# Development: leave empty or use /
# Production example: /admbb
CMS_BASE_PATH=

# Paths (relative to cms/ root — Astro project is at repo root)
CONTENT_DIR=./content
LANDING_DIR=..
LANDING_DATA_DIR=../src/data
LANDING_BLOG_DIR=../src/content/blog
LANDING_PUBLIC_DIR=../public

# Auth
JWT_SECRET=change-this-in-production
JWT_EXPIRY=24h
COOKIE_NAME=bebras_cms_token

# Initial admin (used on first run if no users exist)
ADMIN_EMAIL=admin@bebras.bo
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Admin
